<!--pages/profile/profile.wxml - 个人中心模板-->
<view class="profile-page">
  <!-- 用户信息区域 -->
  <view class="user-section">
    <view class="user-info" wx:if="{{hasUserInfo}}">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <view class="user-detail">
        <text class="nickname">{{userInfo.nickName}}</text>
        <text class="user-tip">让AI帮你成为时尚达人</text>
      </view>
    </view>

    <button class="login-btn" wx:else bindtap="getUserProfile">
      <image class="avatar-default" src="/images/avatar-default.png"></image>
      <text class="login-text">点击登录</text>
    </button>
  </view>

  <!-- 数据统计 -->
  <view class="stats-bar">
    <view class="stat-item">
      <text class="stat-num">{{historyList.length}}</text>
      <text class="stat-label">分析记录</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{collectList.length || 0}}</text>
      <text class="stat-label">收藏搭配</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">0</text>
      <text class="stat-label">获赞</text>
    </view>
  </view>

  <!-- 历史记录/收藏 -->
  <view class="content-section">
    <view class="tab-header">
      <view
        class="tab-item {{currentTab === 'history' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="history"
      >
        历史记录
      </view>
      <view
        class="tab-item {{currentTab === 'collect' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="collect"
      >
        我的收藏
      </view>
    </view>

    <!-- 历史记录列表 -->
    <view class="tab-content" wx:if="{{currentTab === 'history'}}">
      <view class="history-list" wx:if="{{historyList.length > 0}}">
        <view class="history-item" wx:for="{{historyList}}" wx:key="id">
          <view class="history-info" bindtap="viewHistory" data-id="{{item.id}}">
            <image class="history-image" src="{{item.image}}" mode="aspectFill"></image>
            <view class="history-detail">
              <text class="history-title">{{item.garmentType}}</text>
              <text class="history-time">{{item.timestamp}}</text>
            </view>
          </view>
          <view class="history-actions">
            <view class="action-delete" catchtap="deleteHistory" data-id="{{item.id}}" data-index="{{index}}">
              <image class="delete-icon" src="/images/icon-delete.png"></image>
            </view>
          </view>
        </view>
      </view>

      <view class="empty-state" wx:else>
        <image class="empty-icon" src="/images/empty-history.png"></image>
        <text class="empty-text">暂无历史记录</text>
        <text class="empty-tip">快去拍照获取搭配推荐吧</text>
        <button class="empty-btn" bindtap="goToCamera">去拍照</button>
      </view>

      <view class="clear-btn" wx:if="{{historyList.length > 0}}" bindtap="clearHistory">
        清空历史记录
      </view>
    </view>

    <!-- 收藏列表 -->
    <view class="tab-content" wx:if="{{currentTab === 'collect'}}">
      <view class="collect-list" wx:if="{{collectList.length > 0}}">
        <view class="collect-item" wx:for="{{collectList}}" wx:key="id">
          <text>{{item.name}}</text>
        </view>
      </view>

      <view class="empty-state" wx:else>
        <image class="empty-icon" src="/images/empty-collect.png"></image>
        <text class="empty-text">暂无收藏</text>
        <text class="empty-tip">喜欢的搭配可以收藏起来哦</text>
      </view>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-section">
    <view
      class="menu-item"
      wx:for="{{menuList}}"
      wx:key="title"
      bindtap="onMenuTap"
      data-path="{{item.path}}"
    >
      <image class="menu-icon" src="{{item.icon}}"></image>
      <view class="menu-content">
        <text class="menu-title">{{item.title}}</text>
        <text class="menu-desc">{{item.desc}}</text>
      </view>
      <image class="menu-arrow" src="/images/icon-arrow.png"></image>
    </view>
  </view>

  <!-- 其他设置 -->
  <view class="setting-section">
    <view class="setting-item" bindtap="clearCache">
      <text class="setting-text">清除缓存</text>
    </view>
    <view class="setting-item">
      <text class="setting-text">当前版本</text>
      <text class="setting-value">v1.0.0</text>
    </view>
  </view>
</view>
