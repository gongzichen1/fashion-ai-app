/* pages/result/result.wxss - 结果页样式 */

.result-page {
  min-height: 100vh;
  background-color: #F8F8F8;
  padding-bottom: 150rpx;
}

/* 分析结果卡片 */
.analysis-card {
  background-color: #FFFFFF;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.collect-btn {
  padding: 10rpx;
}

.collect-icon {
  width: 44rpx;
  height: 44rpx;
}

.garment-info {
  display: flex;
}

.garment-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  margin-right: 25rpx;
}

.garment-details {
  flex: 1;
}

.detail-row {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.detail-label {
  font-size: 26rpx;
  color: #999;
  width: 130rpx;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
}

.color-tag {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  margin-right: 15rpx;
  border: 2rpx solid #eee;
}

.style-tags, .scene-tags {
  display: flex;
  flex-wrap: wrap;
  flex: 1;
}

.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  border-radius: 20rpx;
  background-color: #FFE4EC;
  color: #FF6B9D;
  margin-right: 10rpx;
  margin-bottom: 5rpx;
}

/* 场景筛选 */
.scene-filter {
  background-color: #FFFFFF;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.scene-scroll {
  white-space: nowrap;
  padding: 0 20rpx;
}

.scene-item {
  display: inline-block;
  padding: 15rpx 35rpx;
  font-size: 28rpx;
  color: #666;
  background-color: #F5F5F5;
  border-radius: 30rpx;
  margin-right: 20rpx;
}

.scene-item.active {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FB1 100%);
  color: #FFFFFF;
}

/* 推荐列表 */
.recommendations {
  padding: 0 20rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.recommend-list {
  display: flex;
  flex-direction: column;
}

.recommend-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.recommend-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx;
  padding-bottom: 0;
}

.recommend-type {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF6B9D;
}

.recommend-tags {
  display: flex;
}

.mini-tag {
  font-size: 22rpx;
  color: #999;
  background-color: #F5F5F5;
  padding: 6rpx 15rpx;
  border-radius: 15rpx;
  margin-left: 10rpx;
}

.recommend-image {
  width: 100%;
  height: 400rpx;
  margin-top: 20rpx;
}

.recommend-content {
  padding: 25rpx;
}

.recommend-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.recommend-reason {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: block;
  margin-bottom: 20rpx;
}

.recommend-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.recommend-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B9D;
}

.buy-btn {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FB1 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  padding: 15rpx 40rpx;
  border-radius: 30rpx;
  border: none;
}

.buy-btn::after {
  border: none;
}

/* 穿搭建议 */
.tips-card {
  background-color: #FFFFFF;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 30rpx;
}

.tips-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: transparent;
  padding: 10rpx 30rpx;
  font-size: 24rpx;
  color: #666;
  border: none;
}

.action-btn::after {
  border: none;
}

.btn-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
