<!--pages/result/result.wxml - 结果页模板-->
<view class="result-page">
  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在生成搭配推荐...</text>
  </view>

  <!-- 内容区域 -->
  <block wx:if="{{!loading && analysisResult}}">
    <!-- 分析结果卡片 -->
    <view class="analysis-card">
      <view class="card-header">
        <text class="card-title">服装分析</text>
        <view class="collect-btn" bindtap="toggleCollect">
          <image
            class="collect-icon"
            src="{{collectStatus ? '/images/icon-collect-active.png' : '/images/icon-collect.png'}}"
          ></image>
        </view>
      </view>

      <view class="garment-info">
        <image
          class="garment-image"
          src="{{analysisResult.image}}"
          mode="aspectFill"
          bindtap="previewImage"
          data-url="{{analysisResult.image}}"
        ></image>

        <view class="garment-details">
          <view class="detail-row">
            <text class="detail-label">服装类型</text>
            <text class="detail-value">{{analysisResult.garmentType}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">主色调</text>
            <view class="color-tag" style="background-color: {{analysisResult.primaryColor}}"></view>
            <text class="detail-value">{{analysisResult.colorName}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">风格定位</text>
            <view class="style-tags">
              <text class="tag" wx:for="{{analysisResult.styles}}" wx:key="*this">{{item}}</text>
            </view>
          </view>
          <view class="detail-row">
            <text class="detail-label">适合场景</text>
            <view class="scene-tags">
              <text class="tag" wx:for="{{analysisResult.scenes}}" wx:key="*this">{{item}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 场景选择 -->
    <view class="scene-filter">
      <scroll-view scroll-x class="scene-scroll">
        <view
          class="scene-item {{selectedScene === item.key ? 'active' : ''}}"
          wx:for="{{scenes}}"
          wx:key="key"
          bindtap="switchScene"
          data-scene="{{item.key}}"
        >
          {{item.name}}
        </view>
      </scroll-view>
    </view>

    <!-- 搭配推荐列表 -->
    <view class="recommendations">
      <view class="section-header">
        <text class="section-title">搭配推荐</text>
      </view>

      <view class="recommend-list" wx:if="{{recommendations.length > 0}}">
        <view class="recommend-card" wx:for="{{recommendations}}" wx:key="id">
          <view class="recommend-header">
            <text class="recommend-type">{{item.type}}</text>
            <view class="recommend-tags">
              <text class="mini-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
            </view>
          </view>

          <image
            class="recommend-image"
            src="{{item.image}}"
            mode="aspectFill"
            bindtap="previewImage"
            data-url="{{item.image}}"
          ></image>

          <view class="recommend-content">
            <text class="recommend-name">{{item.name}}</text>
            <text class="recommend-reason">{{item.reason}}</text>

            <view class="recommend-footer">
              <text class="recommend-price" wx:if="{{item.price}}">{{item.price}}</text>
              <button
                class="buy-btn"
                wx:if="{{item.productUrl}}"
                bindtap="goToProduct"
                data-url="{{item.productUrl}}"
                data-platform="{{item.platform}}"
              >
                查看商品
              </button>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{recommendations.length === 0}}">
        <image class="empty-icon" src="/images/empty.png"></image>
        <text class="empty-text">暂无该场景的搭配推荐</text>
      </view>
    </view>

    <!-- 穿搭建议 -->
    <view class="tips-card" wx:if="{{analysisResult.styleTips}}">
      <view class="section-header">
        <text class="section-title">穿搭建议</text>
      </view>
      <text class="tips-content">{{analysisResult.styleTips}}</text>
    </view>

    <!-- 底部操作栏 -->
    <view class="bottom-bar">
      <button class="action-btn share-btn" open-type="share">
        <image class="btn-icon" src="/images/icon-share.png"></image>
        分享
      </button>
      <button class="action-btn save-btn" bindtap="saveImage">
        <image class="btn-icon" src="/images/icon-save.png"></image>
        保存
      </button>
      <button class="action-btn retake-btn" bindtap="retake">
        <image class="btn-icon" src="/images/icon-camera.png"></image>
        重拍
      </button>
    </view>
  </block>
</view>
