<!--pages/index/index.wxml - 首页模板-->
<view class="container">
  <!-- 顶部欢迎区域 -->
  <view class="header">
    <view class="welcome">
      <text class="greeting">Hi，欢迎使用智搭</text>
      <text class="sub-greeting">一键拍照，AI智能搭配推荐</text>
    </view>
    <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
  </view>

  <!-- 主操作按钮 -->
  <view class="main-action" bindtap="goToCamera">
    <view class="action-content">
      <image class="camera-icon" src="/images/camera-big.png" mode="aspectFit"></image>
      <text class="action-title">拍照识衣</text>
      <text class="action-desc">拍摄服装照片，获取搭配建议</text>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">核心功能</text>
    </view>
    <view class="feature-grid">
      <view class="feature-item" wx:for="{{features}}" wx:key="id">
        <image class="feature-icon" src="{{item.icon}}" mode="aspectFit"></image>
        <text class="feature-title">{{item.title}}</text>
        <text class="feature-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 最近记录 -->
  <view class="section" wx:if="{{recentHistory.length > 0}}">
    <view class="section-header">
      <text class="section-title">最近分析</text>
      <text class="section-more" bindtap="goToCamera">查看更多</text>
    </view>
    <scroll-view class="history-scroll" scroll-x>
      <view class="history-item" wx:for="{{recentHistory}}" wx:key="id" bindtap="goToResult" data-id="{{item.id}}">
        <image class="history-image" src="{{item.image}}" mode="aspectFill"></image>
        <text class="history-title">{{item.garmentType}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 热门风格 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">热门穿搭风格</text>
    </view>
    <view class="style-list">
      <view class="style-item" wx:for="{{hotStyles}}" wx:key="id" bindtap="goToStyleDetail" data-id="{{item.id}}">
        <image class="style-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="style-info">
          <text class="style-name">{{item.name}}</text>
          <text class="style-count">{{item.count}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
