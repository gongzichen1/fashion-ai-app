/* pages/index/index.wxss - 首页样式 */

.container {
  padding-bottom: 120rpx;
}

/* 顶部欢迎区域 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FB1 100%);
}

.welcome {
  display: flex;
  flex-direction: column;
}

.greeting {
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 10rpx;
}

.sub-greeting {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.logo {
  width: 100rpx;
  height: 100rpx;
}

/* 主操作按钮 */
.main-action {
  margin: 30rpx;
  background: linear-gradient(135deg, #FFE4EC 0%, #FFF0F5 100%);
  border-radius: 30rpx;
  padding: 50rpx;
  text-align: center;
  box-shadow: 0 10rpx 40rpx rgba(255, 107, 157, 0.2);
}

.action-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.camera-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.action-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FF6B9D;
  margin-bottom: 10rpx;
}

.action-desc {
  font-size: 26rpx;
  color: #999;
}

/* 区块样式 */
.section {
  margin: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #999;
}

/* 功能网格 */
.feature-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.feature-item {
  width: 48%;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 15rpx;
}

.feature-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #999;
}

/* 历史记录 */
.history-scroll {
  white-space: nowrap;
}

.history-item {
  display: inline-block;
  width: 200rpx;
  margin-right: 20rpx;
}

.history-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  margin-bottom: 10rpx;
}

.history-title {
  display: block;
  font-size: 26rpx;
  color: #333;
  text-align: center;
}

/* 风格列表 */
.style-list {
  display: flex;
  flex-direction: column;
}

.style-item {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.style-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.style-info {
  display: flex;
  flex-direction: column;
}

.style-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.style-count {
  font-size: 24rpx;
  color: #999;
}
